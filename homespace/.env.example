MYSQL_ROOT_PASSWORD=change_me_mysql_root_password
DB_NAME=homespace_model
DB_USER=homespace_user
DB_PASSWORD=change_me_database_password

JWT_SECRET=change_this_to_a_long_random_jwt_secret
JWT_EXPIRE=7d
PASSWORD_VAULT_KEY=change_this_to_a_long_random_vault_key
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_MAX=5000
MAX_FILE_SIZE=10485760

# Admin accounts are server-side only. Keep seeding off unless you need to create a fresh admin.
SEED_ADMIN_USER=false
ADMIN_EMAILS=admin@homespace.local,admin@homespace.ru,admin@example.com
ADMIN_EMAIL=admin@homespace.local
ADMIN_PASSWORD=
ADMIN_FULL_NAME=HomeSpace Admin
